@model IEnumerable<Cargo_Management_Project.Models.ShipmentBooking>
@{
    ViewData["Title"] = "Shipment Bookings";
    var role = ViewBag.Role as string;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Cargo Dashboard</h2>
            <p class="text-muted">Logged in as: <strong>@ViewBag.AssociatedName (@role)</strong></p>
        </div>

        @if (role == "Shipper" || role == "Admin")
        {
            <button type="button" class="btn btn-primary fw-bold px-4 py-2" data-bs-toggle="modal" data-bs-target="#createBookingModal">
                Create New Shipment
            </button>
        }
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 p-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light text-muted">
                    <tr>
                        <th>Booking Ref</th>
                        <th>Shipper</th>
                        <th>Consignee</th>
                        <th>Route</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No shipments found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.BookingNumber</td>
                                <td>@item.ShipperName</td>
                                <td>@item.ConsigneeName</td>
                                <td><small>@item.OriginPort &rarr; @item.DestinationPort</small></td>
                                <td>
                                    <span class="badge bg-success">@item.BookingStatus</span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Details", "ShipmentBooking", new { id = item.BookingId })" class="btn btn-sm btn-outline-secondary px-3">
                                        Manage &rarr;
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">New Shipment Request</h5>
            </div>
            <form href="@Url.Action("Create", "ShipmentBooking")" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    @if (role != "Shipper")
                    {
                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Shipper Company Name</label>
                            <input name="ShipperName" class="form-control" required />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Consignee Name</label>
                        <input name="ConsigneeName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Origin Port</label>
                        <input name="OriginPort" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Destination Port</label>
                        <input name="DestinationPort" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>