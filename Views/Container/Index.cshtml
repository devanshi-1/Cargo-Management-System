@model Cargo_Management_Project.Models.ContainerDashboardViewModel
@using Cargo_Management_Project.Models
@{
    Layout = null; // Setting to null to show full layout control including the custom sidebar theme
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Container & Vessel Manifest Console</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
            :root {
                --sidebar-bg: #0f172a;
                --sidebar-active: #2563eb;
                --sidebar-hover: #1e293b;
                --body-bg: #f8fafc;
                --text-main: #0f172a;
                --accent-blue: #2563eb;
                --border-color: #e2e8f0;
            }

            body {
                background-color: var(--body-bg);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: var(--text-main);
                overflow-x: hidden;
            }

            /* Sidebar Theme Style from Image 1 */
            .sidebar {
                background-color: var(--sidebar-bg);
                min-height: 100vh;
                color: #94a3b8;
            }
            .sidebar .brand-title {
                color: #ffffff;
                font-weight: 700;
                font-size: 1.25rem;
                letter-spacing: 0.5px;
            }
            .sidebar .nav-link {
                color: #94a3b8;
                font-weight: 500;
                padding: 0.8rem 1.5rem;
                border-radius: 8px;
                margin: 0.2rem 0.75rem;
                transition: all 0.2s;
            }
            .sidebar .nav-link:hover {
                background-color: var(--sidebar-hover);
                color: #ffffff;
            }
            .sidebar .nav-link.active {
                background-color: var(--sidebar-active);
                color: #ffffff;
            }

            /* Top Bar Styling */
            .top-navbar {
                background-color: #ffffff;
                border-bottom: 1px solid var(--border-color);
                padding: 1rem 2rem;
            }

            /* Content Dashboard Layout Card Elements */
            .dashboard-card {
                background: #ffffff;
                border: 1px solid var(--border-color);
                border-radius: 16px;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
                margin-bottom: 1.5rem;
                padding: 1.5rem;
            }
            .card-header-title {
                font-size: 1.1rem;
                font-weight: 700;
                color: var(--sidebar-bg);
                display: flex;
                align-items: center;
                gap: 0.5rem;
                margin-bottom: 1.25rem;
            }

            /* Custom Table Design styling weights from Image 1 */
            .custom-table th {
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: #64748b;
                background-color: #f8fafc;
                border-bottom: 2px solid var(--border-color);
                padding: 1rem;
            }
            .custom-table td {
                padding: 1rem;
                vertical-align: middle;
                font-size: 0.9rem;
                border-bottom: 1px solid var(--border-color);
            }

            .btn-accent {
                background-color: var(--accent-blue);
                color: white;
                font-weight: 600;
                border-radius: 8px;
                padding: 0.5rem 1.2rem;
                transition: background 0.2s;
            }
            .btn-accent:hover {
                background-color: #1d4ed8;
                color: white;
            }
    </style>
</head>
<body>

    <div class="container-fluid p-0">
        <div class="row g-0">

            <!-- SIDEBAR PANEL (Theme Styled from Image 1) -->
            <div class="col-md-2 sidebar d-flex flex-column justify-content-between p-3">
                <div>
                    <div class="d-flex align-items-center px-3 py-4 gap-2">
                        <i class="fa-solid fa-ship text-primary fs-3"></i>
                        <span class="brand-title">CargoTrack<br><small style="font-size: 10px; color:#38bdf8; text-transform:uppercase;">Global Logistics</small></span>
                    </div>
                    <ul class="nav flex-column mt-3">
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-chart-pie me-2"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-file-invoice me-2"></i> Bookings & B/L</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="#"><i class="fa-solid fa-box me-2"></i> Vessel Manifests</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-passport me-2"></i> Customs Dec.</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-wallet me-2"></i> Invoices</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-dolly me-2"></i> Terminal Ops</a>
                        </li>
                    </ul>
                </div>

                <div class="px-3 border-top border-secondary pt-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-weight:700;">AD</div>
                        <div>
                            <h6 class="text-white mb-0" style="font-size: 14px;">admin</h6>
                            <small class="text-muted" style="font-size: 11px;">System Administrator</small>
                        </div>
                    </div>
                    <a href="#" class="btn btn-outline-danger btn-sm w-100 mb-2"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Sign Out</a>
                </div>
            </div>

            <!-- MAIN INTERFACE DASHBOARD AREA (Layout structured from Image 2) -->
            <div class="col-md-10 d-flex flex-column">

                <!-- Header Banner Dashboard Meta -->
                <div class="top-navbar d-flex justify-content-between align-items-center">
                    <div>
                        <nav style="--bs-breadcrumb-divider: '/';" aria-label="breadcrumb">
                            <ol class="breadcrumb mb-1" style="font-size: 12px; font-weight: 600; text-transform: uppercase;">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">CargoTrack</a></li>
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Container</a></li>
                                <li class="breadcrumb-item active text-primary" aria-current="page">VesselManifestsConsole</li>
                            </ol>
                        </nav>
                        <h4 class="fw-bold m-0 text-dark">Container & Vessel Manifest Console</h4>
                        <p class="text-muted m-0" style="font-size: 13px;">System Architecture Sandbox Mode: <strong>C# ASP.NET Core Core MVC</strong></p>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-regular fa-bell fs-5 text-muted pointer"></i>
                        <div class="badge bg-primary px-3 py-2 fs-6">
                            <i class="fa-solid fa-user-gear me-2"></i>FREIGHT FORWARDER CONSOLE
                        </div>
                    </div>
                </div>

                <!-- Content Workspace grid layout dynamically structured from Image 2 -->
                <div class="p-4 flex-grow-1">
                    <div class="row">

                        <!-- LEFT COLUMN PANELS (Vessels & Allocated Containers Tables) -->
                        <div class="col-lg-8">

                            <!-- Panel 1: Active Vessels & Voyage Routing -->
                            <div class="dashboard-card">
                                <div class="card-header-title">
                                    <i class="fa-solid fa-calendar-days text-primary"></i> Active Vessels & Voyage Routing
                                </div>
                                <div class="table-responsive">
                                    <table class="table custom-table table-hover align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Voyage #</th>
                                                <th>Vessel Name</th>
                                                <th>Schedule (ETD → ETA)</th>
                                                <th>Route Plan</th>
                                                <th class="text-end">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="fw-bold">V-2026-001A</td>
                                                <td>Oceanic Giant <small class="text-muted">(IMO9823456)</small></td>
                                                <td>03 Jul &rarr; 18 Jul 2026</td>
                                                <td class="text-primary fw-semibold">Shanghai (CNSHA) &rarr; Rotterdam (NLRTM)</td>
                                                <td class="text-end">
                                                    <form asp-action="GenerateManifest" method="post" class="d-inline">
                                                        <input type="hidden" name="voyageId" value="1" />
                                                        <button type="submit" class="btn btn-outline-dark btn-sm fw-bold">Build Manifest</button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold">V-2026-002B</td>
                                                <td>Pacific Explorer <small class="text-muted">(IMO9754321)</small></td>
                                                <td>11 Jul &rarr; 25 Jul 2026</td>
                                                <td class="text-primary fw-semibold">Singapore (SGSIN) &rarr; Los Angeles (USLAX)</td>
                                                <td class="text-end">
                                                    <form asp-action="GenerateManifest" method="post" class="d-inline">
                                                        <input type="hidden" name="voyageId" value="2" />
                                                        <button type="submit" class="btn btn-outline-dark btn-sm fw-bold">Build Manifest</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Panel 2: Allocated Cargo Containers -->
                            <div class="dashboard-card">
                                <div class="card-header-title">
                                    <i class="fa-solid fa-boxes-stacked text-primary"></i> Allocated Cargo Containers
                                </div>
                                <div class="table-responsive">
                                    <table class="table custom-table table-hover align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Container #</th>
                                                <th>Type</th>
                                                <th>Booking Ref</th>
                                                <th>Seal Number</th>
                                                <th>Staging Status</th>
                                                <th class="text-end">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model?.AllocatedContainers != null && Model.AllocatedContainers.Any())
                                            {
                                                @foreach (var container in Model.AllocatedContainers)
                                                {
                                                    <tr>
                                                        <td class="fw-bold text-dark">@container.ContainerNumber</td>
                                                        <td><span class="badge bg-light text-dark border">@container.ContainerType</span></td>
                                                        <td class="text-muted">BK-@container.BookingId</td>
                                                        <td>
                                                            @if (string.IsNullOrEmpty(container.SealNumber))
                                                            {
                                                                <span class="text-danger small fw-semibold">UNSEALED</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-magenta fw-bold" style="color: #db2777;">@container.SealNumber</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <span class="badge @(container.ContainerStatus == ContainerStatus.LOADED ? "bg-info" : container.ContainerStatus == ContainerStatus.EMPTY ? "bg-secondary" : "bg-success") text-uppercase">
                                                                @container.ContainerStatus
                                                            </span>
                                                        </td>
                                                        <td class="text-end">
                                                            @if (string.IsNullOrEmpty(container.SealNumber))
                                                            {
                                                                <form asp-action="LoadContainer" method="post" class="d-flex justify-content-end gap-1">
                                                                    <input type="hidden" name="ContainerId" value="@container.ContainerId" />
                                                                    <input type="text" name="SealNumber" class="form-control form-control-sm d-inline-block" style="width: 100px;" placeholder="Seal #" required />
                                                                    <button type="submit" class="btn btn-success btn-sm">Seal</button>
                                                                </form>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-success small fw-bold"><i class="fa-solid fa-lock me-1"></i> Sealed & Loaded</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="6" class="text-center py-4 text-muted">No operational container allocations tracked dynamically in this deployment scope.</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>

                        <!-- RIGHT COLUMN PANEL (Assign container to Booking form panel layout) -->
                        <div class="col-lg-4">
                            <div class="dashboard-card h-100">
                                <div class="card-header-title">
                                    <i class="fa-solid fa-cube text-primary"></i> Assign container to Booking
                                </div>

                                <form asp-action="AssignContainer" method="post" class="mt-2">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-secondary" style="font-size: 13px;">Target Booking Reference</label>
                                        <select name="BookingId" class="form-select py-2" required>
                                            <option value="">Select active confirmed booking</option>
                                            <option value="1001">BK-20260713-1001</option>
                                            <option value="1002">BK-20260713-1002</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-secondary" style="font-size: 13px;">Container Type Allocation</label>
                                        <select name="ContainerType" class="form-select py-2" required>
                                            <option value="DRY">Dry Van (General Purpose)</option>
                                            <option value="REEFER">Reefer (Refrigerated)</option>
                                            <option value="FLAT_RACK">Flat Rack</option>
                                            <option value="OPEN_TOP">Open Top</option>
                                        </select>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold text-secondary" style="font-size: 13px;">Container Number (Optional)</label>
                                        <input type="text" name="ContainerNumber" class="form-control py-2" placeholder="Leave empty for auto-generation" />
                                    </div>

                                    <button type="submit" class="btn btn-accent w-100 py-2.5">
                                        <i class="fa-solid fa-plus-circle me-2"></i>Allocate Equipment
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Global Module Footer Elements -->
                <footer class="mt-auto py-3 bg-dark text-white px-4 border-top border-secondary d-flex justify-content-between align-items-center" style="font-size: 12px; background-color: #0b0f19 !important;">
                    <div>
                        <strong>International Cargo Infrastructure Engine</strong> &copy; 2026 All rights reserved.
                    </div>
                    <div class="text-muted">
                        Database Connection: <span class="text-success fw-bold">SQL Server (EF Core)</span>
                    </div>
                </footer>

            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>